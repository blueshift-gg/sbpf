{
	"name": "@blueshift-gg/sbpf-assembler",
	"description": "Assembler to assemble and link sbpf assembly to bytecode",
	"version": "0.2.0",
	"types": "./dist/web/sbpf_assembler.d.ts",
	"main": "./dist/node/sbpf_assembler.js",
	"browser": "./dist/web/sbpf_assembler.js",
	"exports": {
		".": {
			"node": {
				"types": "./dist/node/sbpf_assembler.d.ts",
				"import": "./dist/node/sbpf_assembler.js",
				"require": "./dist/node/sbpf_assembler.js"
			},
			"browser": {
				"types": "./dist/web/sbpf_assembler.d.ts",
				"default": "./dist/web/sbpf_assembler.js"
			},
			"import": {
				"types": "./dist/bundler/sbpf_assembler.d.ts",
				"default": "./dist/bundler/sbpf_assembler.js"
			},
			"require": {
				"types": "./dist/node/sbpf_assembler.d.ts",
				"default": "./dist/node/sbpf_assembler.js"
			}
		},
		"./bundler": "./dist/bundler/sbpf_assembler.js",
		"./web": "./dist/web/sbpf_assembler.js",
		"./node": "./dist/node/sbpf_assembler.js",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"sbpf",
		"rust",
		"wasm"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/blueshift-gg/sbpf.git"
	}
}
